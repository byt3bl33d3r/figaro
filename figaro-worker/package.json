{
  "name": "figaro-worker-bun",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "mkdir -p dist && bun build src/index.ts --compile --asset-naming [name].[ext] --outfile dist/figaro-worker",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "dev:supervisor": "bun run src/index.ts --supervisor"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.70",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/resources": "^1.29.0",
    "@opentelemetry/sdk-trace-base": "^1.29.0",
    "@opentelemetry/semantic-conventions": "^1.29.0",
    "nats": "^2.29.3",
    "pyodide": "^0.29.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  }
}
